pdf_ft = final_table.toPandas()

# Pivot para matriz 3x2
heat = pdf_ft.pivot(index="pocket_bin", columns="blitz_flag", values="avg_epa").reindex(["0. Muy colapsado", "1. Colapsado", "2. Pocket limpio"])


plt.figure(figsize=(7,4.5))
sns.heatmap(heat, annot=True, fmt=".3f", cmap="RdYlGn", center=0)
plt.title("Avg EPA por Pocket y Blitz")
